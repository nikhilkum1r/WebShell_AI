# ─────────────────────────────────────────────────────────────
# Webshell Detector — Environment Configuration
# Copy this file to .env and customise as needed.
# The app will auto-load .env if present.
# ─────────────────────────────────────────────────────────────

# API
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development        # development | production
DEBUG=false

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Prediction threshold (0.0 – 1.0)
PREDICTION_THRESHOLD=0.5

# Max files per bulk request
BULK_MAX_FILES=50

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Model loading: v1 (basic) | v2 (powerful retraining)
MODEL_VERSION=v2
